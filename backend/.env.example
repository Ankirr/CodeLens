# CodeLens Configuration

# Required: Get a free key at https://console.groq.com/
GROQ_API_KEY=

# Optional: Generate a free token at https://github.com/settings/tokens
# Increases GitHub API rate limits (highly recommended)
GITHUB_TOKEN=

# Database configuration
# For production (PostgreSQL): postgresql://user:password@localhost:5432/codelens
# Leave blank to automatically use local SQLite fallback: sqlite+aiosqlite:///./codelens.db
DATABASE_URL=
